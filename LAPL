function normalizePhone(p){
  var d = String(p||'').replace(/[^0-9]/g,'');
  if (d.length === 10) d = '91' + d;      // assume India
  if (d.length === 12 && d.indexOf('91')===0) return d;
  return d; // best effort
}
function sendSMS(phone, message){
  return new Promise(function(resolve, reject){
    if (!MSG91_AUTHKEY) return reject(new Error('SMS not configured'));
    var to = normalizePhone(phone);
    if (!to || to.length < 12) return reject(new Error('Invalid phone'));
    // MSG91 legacy flow/sendhttp API
    var params = 'authkey=' + encodeURIComponent(MSG91_AUTHKEY)
      + '&mobiles=' + encodeURIComponent(to)
      + '&message=' + encodeURIComponent(message)
      + '&sender=' + encodeURIComponent(MSG91_SENDER)
      + '&route=' + encodeURIComponent(MSG91_ROUTE)
      + '&country=91'
      + (MSG91_DLT_TEID ? '&DLT_TE_ID=' + encodeURIComponent(MSG91_DLT_TEID) : '');
    var req = https.request({ hostname:'api.msg91.com', path:'/api/sendhttp.php?' + params, method:'GET' }, function(res){
      var data=''; res.on('data',function(c){data+=c;});
      res.on('end',function(){ if(res.statusCode>=200&&res.statusCode<300) resolve(data); else reject(new Error('SMS failed: '+data)); });
    });
    req.on('error', reject); req.end();
  });
}
function trySMS(phone, message, tag){
  if (!MSG91_AUTHKEY) { console.log('[sms] skipped (no MSG91_AUTHKEY) ' + (tag||'')); return; }
  if (!phone) { console.log('[sms] skipped (no phone) ' + (tag||'')); return; }
  sendSMS(phone, message).then(function(){ console.log('[sms] sent ' + (tag||'')); })
    .catch(function(e){ console.error('[sms] failed ' + (tag||'') + ': ' + e.message); });
}

function verifyGoogleToken(idToken) {
  return new Promise(function (resolve, reject) {
    const req = https.request({ hostname: 'oauth2.googleapis.com', path: '/tokeninfo?id_token=' + encodeURIComponent(idToken), method: 'GET' }, function (res) {
      let data = ''; res.on('data', function (c) { data += c; });
      res.on('end', function () { try { const j = JSON.parse(data); if (res.statusCode === 200 && j.sub) resolve(j); else reject(new Error(j.error || 'Invalid token')); } catch (e) { reject(new Error('Bad response from Google')); } });
    });
    req.on('error', reject); req.end();
  });
}
function sendEmail(to, subject, text, html) {
  return new Promise(function (resolve, reject) {
    if (!RESEND_API_KEY) return reject(new Error('Email is not configured'));
    const payload = { from: MAIL_FROM, to: [to], subject: subject, text: text };
    if (html) payload.html = html;
    const body = JSON.stringify(payload);
    const req = https.request({
      hostname: 'api.resend.com', path: '/emails', method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(body), 'Authorization': 'Bearer ' + RESEND_API_KEY }
    }, function (res) {
      let data = ''; res.on('data', function (c) { data += c; });
      res.on('end', function () {
        try {
          const j = JSON.parse(data);
          if (res.statusCode >= 200 && res.statusCode < 300) resolve(j);
          else reject(new Error((j && (j.message || j.error)) || 'Email send failed'));
        } catch (e) { reject(new Error('Bad response from email service')); }
      });
    });
    req.on('error', reject); req.write(body); req.end();
  });
}

// Fire-and-forget: never let email problems break an order.
function userPhone(userId, order){
  try{
    if (order && order.delivery && order.delivery.phone) return order.delivery.phone;
    var p = db.profiles[userId];
    if (p && p.phone) return p.phone;
    var u = db.users.find(function(x){return x.id===userId;});
    return u ? u.phone : '';
  }catch(e){ return ''; }
}
function sendOrderConfirmation(userId, order) {
  try {
    const user = db.users.find(function (u) { return u.id === userId; });
    if (!user || !user.email) return;
    if (!RESEND_API_KEY) { console.log('[email] skipped (no RESEND_API_KEY) for order ' + order.id); return; }
    var ph = userPhone(userId, order);
