        const a = Buffer.from(expected), b = Buffer.from(String(razorpay_signature||''));
        if (a.length !== b.length || !crypto.timingSafeEqual(a, b)) return send(res, 400, { error: 'Invalid signature' });
        if (order.status !== 'placed') {
          order.status = 'placed'; order.placedAt = new Date().toISOString();
          const rupees = Math.round(order.amount/100);
          db.wallets[userId] = walletBal(userId) + rupees;
          (db.walletTxns[userId] = db.walletTxns[userId] || []).push({ type:'credit', amount: rupees, at: new Date().toISOString(), note:'Wallet top-up' });
          saveDB();
        }
        return send(res, 200, { balance: walletBal(userId) });
      }
      // Pay for a cart entirely from wallet balance
      if (url === '/api/wallet/checkout' && req.method === 'POST') {
        if (!userId) return send(res, 401, { error: 'Please log in' });
        const { items, delivery } = await readBody(req);
        const { total, lines } = priceCart(items);
        if (walletBal(userId) < total) return send(res, 400, { error: 'Insufficient wallet balance' });
        db.wallets[userId] = walletBal(userId) - total;
        (db.walletTxns[userId] = db.walletTxns[userId] || []).push({ type:'debit', amount: total, at: new Date().toISOString(), note:'Speaker order' });
        const localId = 'LSP' + Date.now().toString(36).toUpperCase();
        db.orders.push({ id: localId, userId, razorpayOrderId: 'wallet', amount: total*100, status: 'placed', items: lines, delivery: delivery||{}, createdAt: new Date().toISOString(), placedAt: new Date().toISOString(), tracking:'Paid', courier:'', trackingNo:'', paidWith:'wallet' });
        saveDB();
        return send(res, 200, { order: shapeOrder(db.orders[db.orders.length-1]), balance: walletBal(userId) });
      }
      // ----- REVIEWS -----
      if (url.startsWith('/api/reviews') && req.method === 'GET') {
        const q = new URLSearchParams(req.url.split('?')[1] || '');
        const pid = parseInt(q.get('product'), 10);
        const list = db.reviews.filter(r => r.productId === pid).slice().reverse()
          .map(r => ({ name: r.name, rating: r.rating, text: r.text, at: r.at }));
        const avg = list.length ? (list.reduce((s,r)=>s+r.rating,0)/list.length) : 0;
        return send(res, 200, { reviews: list, average: Math.round(avg*10)/10, count: list.length });
      }
      if (url === '/api/reviews' && req.method === 'POST') {
        if (!userId) return send(res, 401, { error: 'Please log in to review' });
        const { productId, rating, text } = await readBody(req);
        const pid = parseInt(productId, 10);
        // must have a placed order containing this product name
        const prod = CATALOG.get(pid);
        if (!prod) return send(res, 400, { error: 'Unknown product' });
        const bought = db.orders.some(o => o.userId === userId && o.status === 'placed' && (o.items||[]).some(it => it.name === prod.name));
        if (!bought) return send(res, 403, { error: 'You can only review products you have purchased' });
        if (db.reviews.some(r => r.productId === pid && r.userId === userId)) return send(res, 409, { error: 'You already reviewed this product' });
        const user = db.users.find(u => u.id === userId);
        const rt = Math.max(1, Math.min(5, parseInt(rating, 10) || 0));
        db.reviews.push({ productId: pid, userId, name: user ? user.name : 'Customer', rating: rt, text: String(text||'').slice(0,1000), at: new Date().toISOString() });
        saveDB();
        return send(res, 200, { ok: true });
      }
      // ----- ADMIN: update order tracking stage -----
      if (url === '/api/admin/track' && req.method === 'POST') {
        const b = await readBody(req);
        if (b.key !== SESSION_SECRET) return send(res, 403, { error: 'Forbidden' });
        const o = db.orders.find(x => x.id === b.id);
        if (!o) return send(res, 404, { error: 'Order not found' });
        if (b.stage && !TRACK_STAGES.includes(b.stage)) return send(res, 400, { error: 'Bad stage' });
        if (b.stage) { o.tracking = b.stage; if (b.stage==='Out for Delivery' || b.stage==='Delivered') { var ph2 = userPhone(o.userId, o); trySMS(ph2, 'LSPLASH: Order ' + o.id + ' is now ' + b.stage + (o.courier?(' via ' + o.courier + (o.trackingNo?' (' + o.trackingNo + ')':'')):'') + '.', 'ship ' + o.id); } }
        if (b.courier !== undefined) o.courier = String(b.courier).slice(0,60);
        if (b.trackingNo !== undefined) o.trackingNo = String(b.trackingNo).slice(0,80);
        if (b.codPaid !== undefined) o.codPaid = !!b.codPaid;
        saveDB();
        return send(res, 200, { ok: true });
      }
      if (url.startsWith('/api/admin/orders')) {
        const q = new URLSearchParams(req.url.split('?')[1] || '');
        if (q.get('key') !== SESSION_SECRET) return send(res, 403, { error: 'Forbidden' });
        const list = db.orders.filter(o => o.status === 'placed').slice().reverse().map(function(o){
          var u = db.users.find(function(x){return x.id===o.userId;}) || {};
          return { id:o.id, tracking:o.tracking||'Paid', courier:o.courier||'', trackingNo:o.trackingNo||'', total: Math.round(o.amount/100), items:o.items, at:o.placedAt, paidWith:o.paidWith||'razorpay', codPaid: !!o.codPaid, customer: (o.delivery&&o.delivery.name)||u.name||'', email: u.email||'', phone: (o.delivery&&o.delivery.phone)||u.phone||'', address: o.delivery ? [o.delivery.address,o.delivery.city,o.delivery.pin].filter(Boolean).join(', ') : '' };
        });
        return send(res, 200, { orders: list, stages: TRACK_STAGES });
      }
      if (url === '/api/chat' && req.method === 'POST') {
        const { messages } = await readBody(req);
        if (!Array.isArray(messages) || !messages.length) return send(res, 400, { error: 'No messages' });
        const trimmed = messages.slice(-12); // keep last few turns
        try {
          const reply = await askAI(trimmed);
          return send(res, 200, { reply });
        } catch (e) {
          return send(res, 200, { reply: "Sorry, I'm having trouble right now. Please try again in a moment." });
        }
      }
      return send(res, 404, { error: 'Not found' });
    } catch (e) {
      return send(res, 400, { error: e.message || 'Request failed' });
    }
  }

  // Admin inbox page (HTML) at /admin?key=SESSION_SECRET
  if (url === '/admin') {
    const q = new URLSearchParams(req.url.split('?')[1] || '');
    if (q.get('key') !== SESSION_SECRET) { res.writeHead(403, {'Content-Type':'text/html'}); return res.end('<h2 style="font-family:sans-serif">Forbidden. Add ?key=YOUR_SESSION_SECRET to the URL.</h2>'); }
    res.writeHead(200, { 'Content-Type': 'text/html' });
    return res.end(ADMIN_HTML.replace(/__KEY__/g, encodeURIComponent(q.get('key'))));
  }
  // Everything else -> the embedded store page
  res.writeHead(200, { 'Content-Type': 'text/html' });
  res.end(PAGE_HTML.replace('</head>', '<script>window.LSPLASH_GOOGLE_CLIENT_ID=' + JSON.stringify(GOOGLE_CLIENT_ID) + ';</script></head>'));
});

server.listen(PORT, '0.0.0.0', () => {
  console.log(`\nLSPLASH store running.  Open  http://localhost:${PORT}\n(Press Control-C to stop.)\n`);
});
