/* ---------- server ---------- */
const server = http.createServer(async (req, res) => {
  const url = req.url.split('?')[0];
  const userId = readSession(req);

  // API routes
  if (url.startsWith('/api/')) {
    try {
      if (url === '/api/otp/request' && req.method === 'POST') {
        const { email } = await readBody(req);
        if (!email || !/\S+@\S+\.\S+/.test(email)) return send(res, 400, { error: 'Enter a valid email' });
        if (!RESEND_API_KEY) return send(res, 503, { error: 'Email login is unavailable right now' });
        const code = String(Math.floor(100000 + Math.random() * 900000));
        OTPS.set(String(email).toLowerCase(), { code: code, expires: Date.now() + OTP_TTL_MS, tries: 0 });
        const text = 'Your LSPLASH login code is ' + code + '. It expires in 4 minutes.';
        const html = '<div style="font-family:-apple-system,Segoe UI,Arial,sans-serif;max-width:420px;margin:0 auto;padding:32px 24px;text-align:center"><div style="font-size:18px;font-weight:600;letter-spacing:3px;color:#1d1d1f;margin-bottom:24px">LSPLASH</div><div style="color:#86868b;font-size:14px;margin-bottom:8px">Your login code</div><div style="font-size:38px;font-weight:700;letter-spacing:8px;color:#1d1d1f;margin:8px 0 20px">' + code + '</div><div style="color:#86868b;font-size:13px">This code expires in 4 minutes.</div></div>';
        try { await sendEmail(String(email).toLowerCase(), 'Your LSPLASH login code: ' + code, text, html); }
        catch (e) { return send(res, 502, { error: 'Could not send the code. Try again.' }); }
        var existing = db.users.find(function(u){return u.email===String(email).toLowerCase();});
        if (existing && existing.phone) trySMS(existing.phone, 'LSPLASH login code: ' + code + '. Valid 4 min.', 'otp');
        return send(res, 200, { ok: true });
      }
      if (url === '/api/otp/verify' && req.method === 'POST') {
        const { email, code } = await readBody(req);
        const key = String(email || '').toLowerCase();
        const rec = OTPS.get(key);
        if (!rec) return send(res, 400, { error: 'Request a code first' });
        if (Date.now() > rec.expires) { OTPS.delete(key); return send(res, 400, { error: 'Code expired, request a new one' }); }
        rec.tries++;
        if (rec.tries > 5) { OTPS.delete(key); return send(res, 429, { error: 'Too many attempts, request a new code' }); }
        if (String(code) !== rec.code) return send(res, 401, { error: 'Incorrect code' });
        OTPS.delete(key);
        const user = findOrCreateUser(key, null, null);
        return send(res, 200, { user: publicUser(user) }, { 'Set-Cookie': `lsp_sess=${encodeURIComponent(signSession(user.id))}; HttpOnly; Path=/; SameSite=Lax; Max-Age=604800` });
      }
      if (url === '/api/google-login' && req.method === 'POST') {
        const { credential } = await readBody(req);
        if (!credential) return send(res, 400, { error: 'Missing Google token' });
        if (!GOOGLE_CLIENT_ID) return send(res, 503, { error: 'Google login not configured' });
        let info;
        try { info = await verifyGoogleToken(credential); } catch (e) { return send(res, 401, { error: 'Google verification failed' }); }
        if (!info || !info.email || info.aud !== GOOGLE_CLIENT_ID) return send(res, 401, { error: 'Invalid Google token' });
        if (info.email_verified === false || info.email_verified === 'false') return send(res, 401, { error: 'Google email not verified' });
        const user = findOrCreateUser(info.email, info.name, null);
        return send(res, 200, { user: publicUser(user) }, { 'Set-Cookie': `lsp_sess=${encodeURIComponent(signSession(user.id))}; HttpOnly; Path=/; SameSite=Lax; Max-Age=604800` });
      }
      if (url === '/api/signup' && req.method === 'POST') {
        const { name, email, phone, password } = await readBody(req);
        if (!name || !email || !phone || !password) return send(res, 400, { error: 'All fields are required' });
        if (!/\S+@\S+\.\S+/.test(email)) return send(res, 400, { error: 'Enter a valid email' });
